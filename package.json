{
  "name": "Scribe",
  "displayName": "Scribe",
  "description": "Permette di creare dei commenti basandosi sulla personalità dell'utente",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scribe.generate",
        "title": "Scribe: Genera Commento"
      }
    ],
    "keybindings": [
      {
        "command": "scribe.acceptInline",
        "key": "tab",
        "when": "scribe.suggestionVisible && editorTextFocus && !editorTabMovesFocus"
      }
    ],
    "configuration": {
      "title": "Scribe",
      "properties": {
        "scribe.apiKey": {
          "type": "string",
          "default": "",
          "description": "Inserisci la tua Hugging Face API Key"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "scribe.generate",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scribe-sidebar",
          "title": "Scribe",
          "icon": "$(comment-add)"
        }
      ]
    },
    "views": {
      "scribe-sidebar": [
        {
          "type": "webview",
          "id": "scribe.personaView",
          "name": "Gestisci Persona"
        },
        {
          "type": "webview",
          "id": "scribe.userView",
          "name": "Gestione Utenti"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.14"
  }
}
